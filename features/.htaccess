# Feature pages inside DataLynkr_Home/features/
# Clean URLs at datalynkr.com/features/slug are handled by ../public_html/.htaccess

Options -MultiViews -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /DataLynkr_Home/features/

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^([^/.]+)/?$ $1.html [END,NC]

  RewriteCond %{THE_REQUEST} \s[^\s]*\.html[\s?] [NC]
  RewriteRule ^([^/]+)\.html$ /features/$1 [R=301,L,NC]
</IfModule>
