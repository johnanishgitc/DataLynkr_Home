# Static site — no Passenger / Node.js server needed.
# Apache serves the static export directly.

Options -MultiViews

DirectoryIndex index.html

# Stop mod_dir from auto-redirecting /login -> /login/ when a stale empty dir exists.
<IfModule mod_dir.c>
  DirectorySlash Off
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /Hometest/

  # Known app routes -> .html.
  # [END] instead of [L]: in .htaccess context Apache re-processes all rules after every
  # internal rewrite. Without [END], the legacy .html->clean-URL redirect rule fires on
  # the re-pass and 301s back to the original URL, creating an infinite redirect loop.
  RewriteRule ^(about|pricing|contact|support|login|privacy|terms|changepswd)/?$ $1.html [END,NC]

  # Feature pages -> .html (same [END] rationale as above).
  RewriteRule ^features/(authorization-workflows|custom-reports|daily-ledger-reports|dynamic-dashboards|extend-portal-customers|invoice-creation|modern-bcommerce-ordering|offline-transactions|payments-collections|sales-order-management|stock-summary)/?$ features/$1.html [END,NC]

  # Legacy *.html bookmarks -> clean URLs (browser request only — not internal rewrites)
  RewriteCond %{THE_REQUEST} \s[^\s]*\.html[\s?] [NC]
  RewriteRule ^features/([^/]+)\.html$ features/$1 [R=301,L,NC]
  RewriteRule ^code\.html$ ./ [R=301,L,NC]
  RewriteRule ^(about|pricing|contact|support|login|privacy|terms|changepswd)\.html$ $1 [R=301,L,NC]

  # Trailing slash -> clean URL (browser request only; skip real asset directories)
  RewriteCond %{THE_REQUEST} \s[^\s]*/.+?/[\s?] [NC]
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)/$ $1 [R=301,L]

  # Serve .html for any other clean URL (works even when stale directories exist).
  # [END] prevents re-processing loop (same reason as above).
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [END]
</IfModule>
