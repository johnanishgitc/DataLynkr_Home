# Static site — served from public_html/DataLynkr_Home/
# Clean URLs (datalynkr.com/login, etc.) are handled by ../public_html/.htaccess

Options -MultiViews

DirectoryIndex index.html

# ─── GZIP / BROTLI COMPRESSION ───────────────────────────────────────────────
# Fixes "No compression applied" from PageSpeed (est savings 121 KiB+)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE text/javascript application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/ld+json
  AddOutputFilterByType DEFLATE application/xml application/xhtml+xml
  AddOutputFilterByType DEFLATE application/rss+xml application/atom+xml
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/woff2 font/woff font/ttf application/font-woff
</IfModule>

# ─── CACHE CONTROL ───────────────────────────────────────────────────────────
# Fixes "Use efficient cache lifetimes" from PageSpeed (est savings 23,122 KiB)
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML pages: no long cache (always check for fresh version)
  ExpiresByType text/html "access plus 0 seconds"

  # CSS & JavaScript: 1 year (Next.js hashes filenames, so cache-bust is automatic)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/x-javascript "access plus 1 year"

  # Images: 1 year
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Video: 1 year
  ExpiresByType video/mp4 "access plus 1 year"
  ExpiresByType video/webm "access plus 1 year"

  # Fonts: 1 year
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"

  # Manifest & JSON: 1 day
  ExpiresByType application/json "access plus 1 day"
  ExpiresByType application/manifest+json "access plus 1 day"
</IfModule>

# Immutable cache for hashed Next.js assets (/_next/static/chunks/*)
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(webp|png|jpg|jpeg|gif|svg|ico|mp4|webm|woff2|woff)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /DataLynkr_Home/

  # Homepage when accessed via /DataLynkr_Home/
  RewriteRule ^$ index.html [END]

  RewriteRule ^changepswd/?$ /reset-password/ [R=301,L,NC]
  RewriteRule ^changepswd\.html$ /reset-password/ [R=301,L,NC]

  # Known app routes -> /index.html
  RewriteRule ^(about|pricing|contact|support|login|signup|forgot-password|reset-password|privacy-policy|terms-of-service)/?$ $1/index.html [END,NC]

  # Feature pages -> /index.html
  RewriteRule ^features/(authorization-workflows|custom-reports|daily-ledger-reports|dynamic-dashboards|extend-portal-customers|invoice-creation|modern-bcommerce-ordering|offline-transactions|payments-collections|sales-order-management|stock-summary)/?$ features/$1/index.html [END,NC]

  # Legacy *.html bookmarks -> clean URLs (browser request only)
  RewriteCond %{THE_REQUEST} \s[^\s]*\.html[\s?] [NC]
  RewriteRule ^features/([^/]+)\.html$ /features/$1/ [R=301,L,NC]
  RewriteRule ^code\.html$ / [R=301,L,NC]
  RewriteRule ^(about|pricing|contact|support|login|signup|forgot-password|privacy-policy|terms-of-service)\.html$ /$1/ [R=301,L,NC]

  # Serve index.html inside a directory for other clean URLs
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.+?)/?$ $1/index.html [END]
</IfModule>
