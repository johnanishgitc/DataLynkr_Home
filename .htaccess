# Static site — served from public_html/DataLynkr_Home/
# Clean URLs (datalynkr.com/login, etc.) are handled by ../public_html/.htaccess

Options -MultiViews

DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /DataLynkr_Home/

  # Homepage when accessed via /DataLynkr_Home/
  RewriteRule ^$ index.html [END]

  # Known app routes -> .html
  RewriteRule ^(about|pricing|contact|support|login|privacy|terms|changepswd)/?$ $1.html [END,NC]

  # Feature pages -> .html
  RewriteRule ^features/(authorization-workflows|custom-reports|daily-ledger-reports|dynamic-dashboards|extend-portal-customers|invoice-creation|modern-bcommerce-ordering|offline-transactions|payments-collections|sales-order-management|stock-summary)/?$ features/$1.html [END,NC]

  # Legacy *.html bookmarks -> clean URLs (browser request only)
  RewriteCond %{THE_REQUEST} \s[^\s]*\.html[\s?] [NC]
  RewriteRule ^features/([^/]+)\.html$ /features/$1 [R=301,L,NC]
  RewriteRule ^code\.html$ / [R=301,L,NC]
  RewriteRule ^(about|pricing|contact|support|login|privacy|terms|changepswd)\.html$ /$1 [R=301,L,NC]

  # Trailing slash -> clean URL
  RewriteCond %{THE_REQUEST} \s[^\s]*/.+?/[\s?] [NC]
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)/$ /DataLynkr_Home/$1 [R=301,L]

  # Serve .html for any other clean URL
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [END]
</IfModule>
