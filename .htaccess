# Static site — no Passenger / Node.js server needed.
# Apache serves the static export directly.

Options -MultiViews

DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /Hometest/

  # Legacy *.html bookmarks -> clean URLs (browser request only — not internal rewrites)
  RewriteCond %{THE_REQUEST} \s[^\s]*\.html[\s?] [NC]
  RewriteRule ^features/([^/]+)\.html$ features/$1 [R=301,L,NC]
  RewriteRule ^code\.html$ ./ [R=301,L,NC]
  RewriteRule ^(about|pricing|contact|support|login|privacy|terms|changepswd)\.html$ $1 [R=301,L,NC]

  # Trailing slash -> clean URL (browser request only; skip real asset directories)
  RewriteCond %{THE_REQUEST} \s[^\s]*/.+?/[\s?] [NC]
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)/$ $1 [R=301,L]

  # Serve .html for clean URLs (works even when stale empty route directories exist)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>
