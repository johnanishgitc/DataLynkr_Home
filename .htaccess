# Static site — no Passenger / Node.js server needed.
# Apache serves the static export directly.

Options -MultiViews

DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /Hometest/

  # Legacy .html redirects to clean URLs
  RewriteRule ^features/([^/]+)\.html$ features/$1 [R=301,L,NC]
  RewriteRule ^code\.html$ ./ [R=301,L,NC]
  RewriteRule ^(about|pricing|contact|support|login|privacy|terms|changepswd)\.html$ $1 [R=301,L,NC]

  # Serve the correct .html file for clean URLs (Next.js static export creates /page.html files)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+)$ $1.html [L]
</IfModule>
